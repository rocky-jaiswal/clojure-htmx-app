# PostgreSQL (used by docker-compose to init the DB container)
POSTGRES_DB=htmx_app
POSTGRES_USER=htmx_app
POSTGRES_PASSWORD=changeme

# App database connection (local dev points to localhost)
DATABASE_URL=jdbc:postgresql://localhost:5432/htmx_app?user=htmx_app&password=changeme
DB_POOL_SIZE=10

# JWT signing — passphrase for the encrypted private key (keys/private.pem)
# In production, generate a new RSA key pair with a strong passphrase
PRIVATE_KEY_PASSPHRASE=change-this-to-a-strong-passphrase

# App
PORT=3000
LOG_LEVEL=info

# PostgreSQL (used by docker-compose to init the DB container)
POSTGRES_DB=htmx_app
POSTGRES_USER=htmx_app
POSTGRES_PASSWORD=changeme

# App database connection (local dev points to localhost)
DATABASE_URL=jdbc:postgresql://localhost:5432/htmx_app?user=htmx_app&password=changeme
DB_POOL_SIZE=10

# Session (use a long random string in production)
SESSION_SECRET=change-this-to-a-random-32-char-string

# App
PORT=3000
LOG_LEVEL=info
